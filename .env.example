# =========================================================================
# KH Cloud Environment Configuration Example
# Copy this file to '.env' and populate with your production settings.
# Do NOT commit your actual '.env' file to public source control.
# =========================================================================

# --- DOMAIN SETTINGS ---
# The base domain where your cloud is hosted.
BASE_DOMAIN=yourdomain.com

# --- GOOGLE OAUTH CONFIGURATION ---
# Used for user authentication (signing in).
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- GITHUB OAUTH CONFIGURATION (LEGACY / OPTIONAL AUTH) ---
# Used if you want to support login via GitHub.
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- GITHUB APP INTEGRATION ---
# Essential for Vercel/Railway-style selective repository import and auto-deployments.
# Create the app at: https://github.com/settings/apps/new
#
# Config settings for the App:
# - Homepage URL: https://cloud.yourdomain.com
# - Webhook URL: https://api.yourdomain.com/api/github/webhook
# - Setup URL: https://cloud.yourdomain.com
# - Check: "Redirect on update"
#
# Permissions:
# - Repository:
#   * Contents: Read-only
#   * Metadata: Read-only
#   * Webhooks: Read & write
# - Events Subscription:
#   * Check "Push" event.

# GitHub App ID (numeric identifier)
GITHUB_APP_ID=1234567

# GitHub App Slug (url suffix, e.g. 'my-cloud-app' in github.com/apps/my-cloud-app)
GITHUB_APP_SLUG=your-github-app-slug

# GitHub App Client ID (for identification)
GITHUB_APP_CLIENT_ID=Iv23liDQkhKe8l...

# GitHub App Client Secret
GITHUB_APP_CLIENT_SECRET=your_github_app_client_secret

# GitHub App Private Key (PEM format, multi-line enclosed in quotes)
# Read the downloaded .pem key file, copy everything, and replace real newlines with '\n'
# Example format: "-----BEGIN RSA PRIVATE KEY-----\nMIIE...base64...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_RSA_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# GitHub App Webhook Secret (HMAC verification)
# Must match the string set in the "Webhook Secret" box of the GitHub App settings page.
GITHUB_APP_WEBHOOK_SECRET=your_webhook_hmac_secret_string

# --- OPTIONAL NEXT.js ENVS (Defaults to fallbacks, but can override) ---
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
